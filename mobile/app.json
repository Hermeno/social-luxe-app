{
  "expo": {
    "name": "luxee",
    "slug": "luxee",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.luxee.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Permite ao luxee aceder à câmara para publicar fotos.",
        "NSPhotoLibraryUsageDescription": "Permite ao luxee aceder à galeria para publicar fotos.",
        "NSMicrophoneUsageDescription": "Permite ao luxee gravar áudio em vídeos.",
        "NSLocationWhenInUseUsageDescription": "Permite ao luxee mostrar publicações e perfis próximos de ti."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#4C8CE4"
      },
      "package": "com.luxee.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite ao luxee aceder às tuas fotos.",
          "cameraPermission": "Permite ao luxee usar a câmara."
        }
      ],
      "expo-audio",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4C8CE4",
          "defaultChannel": "messages"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "19550566-94a8-4992-8d1e-25df68e87569"
      }
    },
    "owner": "hermidev"
  }
}
