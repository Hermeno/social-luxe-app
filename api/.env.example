DATABASE_URL="postgresql://neondb_owner:"
JWT_SECRET="changeme_generate_your_own_random_64_byte_hex_string"
JWT_EXPIRES_IN="365d"
PORT=3000
NODE_ENV=development
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=157286400

# Tests need their own api/.env.test with a DATABASE_URL pointing at a SEPARATE
# database (e.g. a dedicated Neon branch) — never the same one as above.
# tests/jest.setup.ts refuses to run if this is missing or points at production,
# because tests/helpers.ts's cleanDb() deletes every row in User, Post, Like, etc.
