generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  TEXT
}

enum FriendshipDuration {
  ONE_DAY
  THREE_DAYS
  SEVEN_DAYS
  THIRTY_DAYS
  PERMANENT
}

enum ReactionType {
  HEART
  FIRE
  LAUGH
  WOW
  SAD
  CLAP
}

enum ReportTarget {
  POST
  USER
  COMMENT
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  countryCode  String
  password     String
  avatar       String?
  bio          String?
  availability String?  @default("Disponível")
  ghostMode    Boolean  @default(false)
  viewsPublic          Boolean  @default(false)
  coinBalance          Int      @default(0)
  contact              String?
  defaultFollowDuration String? @default("forever")
  relationshipStatus   String?
  partnerName          String?
  partnerId            String?
  city                 String?
  district             String?
  autoReply            String?
  showDevice           Boolean  @default(false)
  statusLabel          String?
  lat          Float?
  lng          Float?
  isAdmin      Boolean  @default(false)
  lastSeen     DateTime?
  createdAt    DateTime @default(now())

  posts            Post[]
  friendshipsA     Friendship[]        @relation("FriendA")
  friendshipsB     Friendship[]        @relation("FriendB")
  historyA         FriendshipHistory[] @relation("HistoryA")
  historyB         FriendshipHistory[] @relation("HistoryB")
  likes            Like[]
  comments         Comment[]
  shares           Share[]
  views            View[]
  sentMessages     Message[]           @relation("Sender")
  receivedMessages Message[]           @relation("Receiver")
  msgReactions     MessageReaction[]
  stories          Story[]
  storyViews       StoryView[]         @relation("StoryViewer")
  reactions        Reaction[]
  bookmarks        Bookmark[]
  blocksGiven      Block[]             @relation("Blocker")
  blocksReceived   Block[]             @relation("Blocked")
  reports          Report[]
  groupsCreated    GroupChat[]         @relation("GroupCreator")
  groupMemberships GroupMember[]
  groupMessages    GroupMessage[]      @relation("GroupSender")
  extendVotes      PostExtendVote[]
  highlights       Highlight[]
  coinsSent        LuxeCoin[]          @relation("CoinSender")
  coinsReceived    LuxeCoin[]          @relation("CoinReceiver")
  momentos         Momento[]
  momentoViews     MomentoView[]       @relation("MomentoViewer")
  deviceTokens     DeviceToken[]
  collabPostsA     CollabPost[]        @relation("CollabA")
  collabPostsB     CollabPost[]        @relation("CollabB")
  following        Follow[]            @relation("Follower")
  followers        Follow[]            @relation("Following")
  sentPartnerReqs     PartnerRequest[] @relation("SentPartnerReqs")
  receivedPartnerReqs PartnerRequest[] @relation("ReceivedPartnerReqs")
  partnerPosts     Post[]              @relation("PostPartner")
  products         Product[]
  productSaves     ProductSave[]
  donationsGiven   Donation[]         @relation("DonorDonations")
  donationsReceived Donation[]        @relation("RequesterDonations")
  donationFeedbacks DonationFeedback[] @relation("FeedbackGiver")
  postStickers     PostSticker[]
  stickerLikes     StickerLike[]
  stickerReactions StickerReaction[]
  stickerViews     StickerView[]
  travelObjects    TravelObject[]
  unionsAsA        Union[]        @relation("UnionMemberA")
  unionsAsB        Union[]        @relation("UnionMemberB")
  unionInvites     UnionInvite[]
}

// ─── Post ────────────────────────────────────────────────────────────────────

model Post {
  id              String    @id @default(cuid())
  userId          String
  mediaUrl        String?
  mediaType       MediaType
  caption         String?
  bgColor         String?
  expiresAt       DateTime
  extended        Boolean   @default(false)
  deviceModel     String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  partnerUserId   String?
  partnerAccepted Boolean   @default(false)
  isAnnouncement  Boolean   @default(false)

  stickersEnabled  Boolean   @default(false)
  isTravelEnabled  Boolean   @default(false)

  user           User             @relation(fields: [userId], references: [id])
  partnerUser    User?            @relation("PostPartner", fields: [partnerUserId], references: [id])
  likes          Like[]
  comments       Comment[]
  shares         Share[]
  views          View[]
  reactions      Reaction[]
  bookmarks      Bookmark[]
  extendVotes    PostExtendVote[]
  coins          LuxeCoin[]
  stickers       PostSticker[]
  travelNodes    TravelNode[]
  travelObjects  TravelObject[]
}

// ─── Travel Posts ─────────────────────────────────────────────────────────────

model TravelNode {
  id                 String   @id @default(cuid())
  postId             String
  countryCode        String
  countryName        String
  views              Int      @default(0)
  likes              Int      @default(0)
  comments           Int      @default(0)
  objectsAdded       Int      @default(0)
  firstInteractionAt DateTime @default(now())
  lastInteractionAt  DateTime @default(now()) @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, countryCode])
  @@index([postId])
}

model TravelObject {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  type        String   @default("emoji")
  value       String
  countryCode String
  createdAt   DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId],  references: [id], onDelete: Cascade)

  @@index([postId])
}

// ─── Post Stickers ───────────────────────────────────────────────────────────

model PostSticker {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String   @default("emoji")
  emoji     String
  content   String?
  x         Float
  y         Float
  createdAt DateTime @default(now())

  post      Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     StickerLike[]
  reactions StickerReaction[]
  views     StickerView[]

  @@index([postId])
}

model StickerView {
  id        String      @id @default(cuid())
  stickerId String
  userId    String
  createdAt DateTime    @default(now())

  sticker PostSticker @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([stickerId, userId])
}

model StickerLike {
  id        String      @id @default(cuid())
  stickerId String
  userId    String
  createdAt DateTime    @default(now())

  sticker PostSticker @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([stickerId, userId])
}

model StickerReaction {
  id        String      @id @default(cuid())
  stickerId String
  userId    String
  word      String
  createdAt DateTime    @default(now())

  sticker PostSticker @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([stickerId, userId, word])
}

// ─── Friendship ───────────────────────────────────────────────────────────────

model Friendship {
  id        String             @id @default(cuid())
  userAId   String
  userBId   String
  duration  FriendshipDuration
  expiresAt DateTime?
  renewedAt DateTime?
  createdAt DateTime           @default(now())

  userA User @relation("FriendA", fields: [userAId], references: [id])
  userB User @relation("FriendB", fields: [userBId], references: [id])

  @@unique([userAId, userBId])
}

model FriendshipHistory {
  id        String             @id @default(cuid())
  userAId   String
  userBId   String
  duration  FriendshipDuration
  startedAt DateTime
  endedAt   DateTime

  userA User @relation("HistoryA", fields: [userAId], references: [id])
  userB User @relation("HistoryB", fields: [userBId], references: [id])
}

// ─── Interactions ─────────────────────────────────────────────────────────────

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType
  anonymous Boolean      @default(false)
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  parentId  String?
  createdAt DateTime @default(now())

  user    User      @relation(fields: [userId], references: [id])
  post    Post      @relation(fields: [postId], references: [id])
  parent  Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies Comment[] @relation("Replies")
}

model Share {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])
}

model View {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id          String    @id @default(cuid())
  senderId    String
  receiverId  String
  content     String?
  mediaUrl    String?
  readAt      DateTime?
  replyToId   String?
  createdAt   DateTime  @default(now())

  sender    User              @relation("Sender",   fields: [senderId],   references: [id])
  receiver  User              @relation("Receiver", fields: [receiverId], references: [id])
  replyTo   Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]         @relation("MessageReplies")
  reactions MessageReaction[]

  @@index([senderId, receiverId, createdAt(sort: Desc)])
  @@index([receiverId, senderId, createdAt(sort: Desc)])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

enum GroupType {
  COMMUNITY
  GROUP
}

model GroupChat {
  id          String    @id @default(cuid())
  name        String
  avatar      String?
  description String?
  type        GroupType @default(COMMUNITY)
  createdBy   String
  createdAt   DateTime  @default(now())

  creator  User           @relation("GroupCreator", fields: [createdBy], references: [id])
  members  GroupMember[]
  messages GroupMessage[]
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  isAdmin  Boolean   @default(false)
  joinedAt DateTime  @default(now())

  group GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId],  references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  senderId  String
  content   String?
  replyToId String?
  createdAt DateTime @default(now())

  group   GroupChat     @relation(fields: [groupId],   references: [id], onDelete: Cascade)
  sender  User          @relation("GroupSender",        fields: [senderId],  references: [id], onDelete: Cascade)
  replyTo GroupMessage? @relation("GroupReplies",       fields: [replyToId], references: [id], onDelete: SetNull)
  replies GroupMessage[] @relation("GroupReplies")
}

// ─── Stories ─────────────────────────────────────────────────────────────────

model Story {
  id        String      @id @default(cuid())
  userId    String
  mediaUrl  String
  mediaType MediaType
  expiresAt DateTime
  createdAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id])
  views StoryView[]
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  viewerId  String
  createdAt DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id])
  viewer User  @relation("StoryViewer", fields: [viewerId], references: [id])

  @@unique([storyId, viewerId])
}

// ─── Safety ──────────────────────────────────────────────────────────────────

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetId   String
  targetType ReportTarget
  reason     String
  createdAt  DateTime     @default(now())

  reporter User @relation(fields: [reporterId], references: [id])
}

// ─── Post Extend Vote ────────────────────────────────────────────────────────

model PostExtendVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

// ─── Highlights ──────────────────────────────────────────────────────────────

model Highlight {
  id        String          @id @default(cuid())
  userId    String
  title     String
  coverUrl  String?
  createdAt DateTime        @default(now())

  user  User            @relation(fields: [userId], references: [id])
  posts HighlightPost[]
}

model HighlightPost {
  id          String    @id @default(cuid())
  highlightId String
  mediaUrl    String
  mediaType   MediaType
  caption     String?
  addedAt     DateTime  @default(now())

  highlight Highlight @relation(fields: [highlightId], references: [id])
}

// ─── Challenges ──────────────────────────────────────────────────────────────

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String
  hashtag     String   @unique
  coverUrl    String?
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
}

// ─── Luxe Coins ──────────────────────────────────────────────────────────────

model LuxeCoin {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  postId     String?
  amount     Int
  message    String?
  createdAt  DateTime @default(now())

  sender   User  @relation("CoinSender",   fields: [senderId],   references: [id])
  receiver User  @relation("CoinReceiver", fields: [receiverId], references: [id])
  post     Post? @relation(fields: [postId], references: [id])
}

// ─── Momento ─────────────────────────────────────────────────────────────────

model Momento {
  id        String        @id @default(cuid())
  userId    String
  latitude  Float
  longitude Float
  label     String?
  expiresAt DateTime
  createdAt DateTime      @default(now())

  user    User          @relation(fields: [userId], references: [id])
  viewers MomentoView[]
}

model MomentoView {
  id        String   @id @default(cuid())
  momentoId String
  viewerId  String
  createdAt DateTime @default(now())

  momento Momento @relation(fields: [momentoId], references: [id])
  viewer  User    @relation("MomentoViewer", fields: [viewerId], references: [id])

  @@unique([momentoId, viewerId])
}

// ─── Device Tokens ───────────────────────────────────────────────────────────

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, token])
}

// ─── Collaborative Post ──────────────────────────────────────────────────────

model CollabPost {
  id         String     @id @default(cuid())
  userAId    String
  userBId    String?
  mediaUrlA  String
  mediaUrlB  String?
  mediaTypeA MediaType
  mediaTypeB MediaType?
  caption    String?
  code       String     @unique
  accepted   Boolean    @default(false)
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())

  userA User  @relation("CollabA", fields: [userAId],  references: [id])
  userB User? @relation("CollabB", fields: [userBId],  references: [id])
}

// ─── Follow ───────────────────────────────────────────────────────────────────

model Follow {
  id          String    @id @default(cuid())
  followerId  String
  followingId String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  follower  User @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

// ─── Partner Request ─────────────────────────────────────────────────────────

model PartnerRequest {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  status     String   @default("pending")  // "pending" | "accepted" | "rejected"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("SentPartnerReqs",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedPartnerReqs", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

// ─── Store / Listings ──────────────────────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  sellerId      String
  title         String
  description   String
  price         Float
  currency      String   @default("MZN")
  category      String
  type          String
  images        String[]
  quantity      Int      @default(1)
  city          String?
  country       String?
  hasShipping   Boolean  @default(false)
  shippingPrice Float?
  tags          String[]
  status        String   @default("active")
  views         Int      @default(0)
  saves         Int      @default(0)
  createdAt     DateTime @default(now())

  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  saves_by ProductSave[]
}

model ProductSave {
  id        String   @id @default(cuid())
  productId String
  userId    String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([productId, userId])
}

// ─── Donations (Piedade) ─────────────────────────────────────────────────────

enum DonationType {
  ITEM
  FINANCIAL
}

enum DonationStatus {
  AVAILABLE
  RESERVED
  DELIVERED
  EXPIRED
}

model Donation {
  id          String         @id @default(cuid())
  title       String
  description String?
  photos      String[]
  lat         Float
  lng         Float
  radiusKm    Float          @default(10)
  type        DonationType
  status      DonationStatus @default(AVAILABLE)
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  donorId     String
  donor       User           @relation("DonorDonations",     fields: [donorId],     references: [id])
  requesterId String?
  requester   User?          @relation("RequesterDonations", fields: [requesterId], references: [id])
  feedbacks   DonationFeedback[]
}

model DonationFeedback {
  id         String   @id @default(cuid())
  donationId String
  fromUserId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  donation   Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  from       User     @relation("FeedbackGiver", fields: [fromUserId], references: [id])
}

// ─── União (Duo Profile) ─────────────────────────────────────────────────────

enum UnionType {
  COUPLE
  TWINS
  PARTNERS
  FRIENDS
  CREATIVE
}

enum UnionInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Union {
  id        String    @id @default(cuid())
  name      String
  avatar    String?
  type      UnionType
  bio       String?
  memberAId String
  memberBId String
  createdAt DateTime  @default(now())

  memberA  User           @relation("UnionMemberA", fields: [memberAId], references: [id], onDelete: Cascade)
  memberB  User           @relation("UnionMemberB", fields: [memberBId], references: [id], onDelete: Cascade)
  sentMessages     UnionMessage[] @relation("UnionSender")
  receivedMessages UnionMessage[] @relation("UnionReceiver")
  invitesSent      UnionInvite[]  @relation("InviteFromUnion")

  @@unique([memberAId, memberBId])
  @@index([memberAId])
  @@index([memberBId])
}

model UnionInvite {
  id          String            @id @default(cuid())
  fromUnionId String
  toUserId    String
  status      UnionInviteStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  fromUnion Union @relation("InviteFromUnion", fields: [fromUnionId], references: [id], onDelete: Cascade)
  toUser    User  @relation(fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUnionId, toUserId])
  @@index([toUserId])
}

model UnionMessage {
  id          String   @id @default(cuid())
  fromUnionId String
  toUnionId   String
  content     String?
  mediaUrl    String?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  fromUnion Union @relation("UnionSender",   fields: [fromUnionId], references: [id], onDelete: Cascade)
  toUnion   Union @relation("UnionReceiver", fields: [toUnionId],   references: [id], onDelete: Cascade)

  @@index([fromUnionId, toUnionId, createdAt(sort: Desc)])
  @@index([toUnionId, fromUnionId, createdAt(sort: Desc)])
}

// ─── PasswordReset ────────────────────────────────────────────────────────────

model PasswordReset {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}
