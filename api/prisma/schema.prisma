generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  TEXT
}

enum FriendshipDuration {
  ONE_DAY
  THREE_DAYS
  SEVEN_DAYS
  THIRTY_DAYS
  PERMANENT
}

enum ReactionType {
  HEART
  FIRE
  LAUGH
  WOW
  SAD
  CLAP
}

enum ReportTarget {
  POST
  USER
  COMMENT
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  countryCode  String
  password     String
  avatar       String?
  bio          String?
  availability String?  @default("Disponível")
  ghostMode    Boolean  @default(false)
  viewsPublic          Boolean  @default(false)
  coinBalance          Int      @default(0)
  contact              String?
  defaultFollowDuration String? @default("forever")
  city                 String?
  district             String?
  autoReply            String?
  showDevice           Boolean  @default(false)
  statusLabel          String?
  interests            String[] @default([])
  lat          Float?
  lng          Float?
  isAdmin      Boolean  @default(false)
  lastSeen     DateTime?
  createdAt    DateTime @default(now())

  // ── Conta profissional / comercial ──
  // PERSONAL | PROFESSIONAL. Em PROFESSIONAL o perfil deixa de responder "quem
  // sou" e passa a responder "o que vendo e como falas comigo agora".
  accountType      String   @default("PERSONAL")
  businessCategory String?                        // guardado em PT (ID estável), mostrado traduzido
  businessAddress  String?
  businessHours    Json?                          // 7 entradas: [{ closed, open:"08:00", close:"18:00" }]
  whatsapp         String?                        // número completo com indicativo
  profileActions   String[] @default([])          // call | whatsapp | message | directions

  // Redes sociais: { instagram: "handle", github: "user", ... }. Vale para
  // qualquer conta — um programador com GitHub não é um negócio.
  socialLinks      Json?

  posts            Post[]
  friendshipsA     Friendship[]        @relation("FriendA")
  friendshipsB     Friendship[]        @relation("FriendB")
  historyA         FriendshipHistory[] @relation("HistoryA")
  historyB         FriendshipHistory[] @relation("HistoryB")
  likes            Like[]
  comments         Comment[]
  commentLikes     CommentLike[]
  shares           Share[]
  views            View[]
  sentMessages     Message[]           @relation("Sender")
  receivedMessages Message[]           @relation("Receiver")
  msgReactions     MessageReaction[]
  stories          Story[]
  storyViews       StoryView[]         @relation("StoryViewer")
  reactions        Reaction[]
  bookmarks        Bookmark[]
  blocksGiven      Block[]             @relation("Blocker")
  blocksReceived   Block[]             @relation("Blocked")
  reports          Report[]
  extendVotes      PostExtendVote[]
  highlights       Highlight[]
  coinsSent        LuxeCoin[]          @relation("CoinSender")
  coinsReceived    LuxeCoin[]          @relation("CoinReceiver")
  momentos         Momento[]
  momentoViews     MomentoView[]       @relation("MomentoViewer")
  deviceTokens     DeviceToken[]
  collabPostsA     CollabPost[]        @relation("CollabA")
  collabPostsB     CollabPost[]        @relation("CollabB")
  following        Follow[]            @relation("Follower")
  followers        Follow[]            @relation("Following")
  partnerPosts     Post[]              @relation("PostPartner")
  donationsGiven   Donation[]         @relation("DonorDonations")
  donationsReceived Donation[]        @relation("RequesterDonations")
  donationFeedbacks DonationFeedback[] @relation("FeedbackGiver")
  postStickers     PostSticker[]
  stickerLikes     StickerLike[]
  stickerReactions StickerReaction[]
  stickerViews     StickerView[]
  travelObjects    TravelObject[]
  unionsAsA        Union[]        @relation("UnionMemberA")
  unionsAsB        Union[]        @relation("UnionMemberB")
  unionInvites     UnionInvite[]
  pairingsAsA      Pairing[]      @relation("PairingUserA")
  pairingsAsB      Pairing[]      @relation("PairingUserB")
  circleCaptures   CircleCapture[]
  circleVotes      CircleVote[]
  circleSessionsHosted CircleSession[]       @relation("CircleHost")
  circleMemberships    CircleSessionMember[] @relation("CircleMember")
}

// ─── Post ────────────────────────────────────────────────────────────────────

model Post {
  id              String    @id @default(cuid())
  userId          String
  mediaUrl        String?
  mediaUrls       String[]  @default([])   // álbum: 2+ fotos mostradas em grelha (mediaUrl = 1ª, p/ thumbnail)
  albumOverlays   Json?                     // emojis por foto do álbum, paralelo a mediaUrls: [[{emoji,x,y}], ...]
  mediaType       MediaType
  caption         String?
  bgColor         String?
  expiresAt       DateTime
  extended        Boolean   @default(false)
  deviceModel     String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  partnerUserId   String?
  partnerAccepted Boolean   @default(false)
  isAnnouncement  Boolean   @default(false)

  stickersEnabled  Boolean   @default(false)
  isTravelEnabled  Boolean   @default(false)

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  partnerUser    User?            @relation("PostPartner", fields: [partnerUserId], references: [id], onDelete: SetNull)
  likes          Like[]
  comments       Comment[]
  shares         Share[]
  views          View[]
  reactions      Reaction[]
  bookmarks      Bookmark[]
  extendVotes    PostExtendVote[]
  coins          LuxeCoin[]
  stickers       PostSticker[]
  travelNodes    TravelNode[]
  travelObjects  TravelObject[]
}

// ─── Travel Posts ─────────────────────────────────────────────────────────────

model TravelNode {
  id                 String   @id @default(cuid())
  postId             String
  countryCode        String
  countryName        String
  views              Int      @default(0)
  likes              Int      @default(0)
  comments           Int      @default(0)
  objectsAdded       Int      @default(0)
  firstInteractionAt DateTime @default(now())
  lastInteractionAt  DateTime @default(now()) @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, countryCode])
  @@index([postId])
}

model TravelObject {
  id          String   @id @default(cuid())
  postId      String
  userId      String
  type        String   @default("emoji")
  value       String
  countryCode String
  createdAt   DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId],  references: [id], onDelete: Cascade)

  @@index([postId])
}

// ─── Post Stickers ───────────────────────────────────────────────────────────

model PostSticker {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String   @default("emoji")
  emoji     String
  content   String?
  x         Float
  y         Float
  createdAt DateTime @default(now())

  post      Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     StickerLike[]
  reactions StickerReaction[]
  views     StickerView[]

  @@index([postId])
}

model StickerView {
  id        String      @id @default(cuid())
  stickerId String
  userId    String
  createdAt DateTime    @default(now())

  sticker PostSticker @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([stickerId, userId])
}

model StickerLike {
  id        String      @id @default(cuid())
  stickerId String
  userId    String
  createdAt DateTime    @default(now())

  sticker PostSticker @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([stickerId, userId])
}

model StickerReaction {
  id        String      @id @default(cuid())
  stickerId String
  userId    String
  word      String
  createdAt DateTime    @default(now())

  sticker PostSticker @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([stickerId, userId, word])
}

// ─── Friendship ───────────────────────────────────────────────────────────────

model Friendship {
  id        String             @id @default(cuid())
  userAId   String
  userBId   String
  duration  FriendshipDuration
  expiresAt DateTime?
  renewedAt DateTime?
  createdAt DateTime           @default(now())

  userA User @relation("FriendA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
}

model FriendshipHistory {
  id        String             @id @default(cuid())
  userAId   String
  userBId   String
  duration  FriendshipDuration
  startedAt DateTime
  endedAt   DateTime

  userA User @relation("HistoryA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("HistoryB", fields: [userBId], references: [id], onDelete: Cascade)
}

// ─── Interactions ─────────────────────────────────────────────────────────────

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType
  anonymous Boolean      @default(false)
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  parentId  String?
  createdAt DateTime @default(now())
  editedAt  DateTime?                       // marca "editado" quando o autor altera
  deletedAt DateTime?                       // apagado leve: as respostas sobrevivem

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("Replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("Replies")
  likes   CommentLike[]
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
}

model Share {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model View {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id          String    @id @default(cuid())
  senderId    String
  receiverId  String
  content     String?
  mediaUrl    String?
  readAt      DateTime?
  replyToId   String?
  createdAt   DateTime  @default(now())

  sender    User              @relation("Sender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver  User              @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
  replyTo   Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]         @relation("MessageReplies")
  reactions MessageReaction[]

  @@index([senderId, receiverId, createdAt(sort: Desc)])
  @@index([receiverId, senderId, createdAt(sort: Desc)])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
}

// ─── Stories ─────────────────────────────────────────────────────────────────

model Story {
  id        String      @id @default(cuid())
  userId    String
  mediaUrl  String
  mediaType MediaType
  expiresAt DateTime
  createdAt DateTime    @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  views StoryView[]
}

model StoryView {
  id        String   @id @default(cuid())
  storyId   String
  viewerId  String
  createdAt DateTime @default(now())

  story  Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer User  @relation("StoryViewer", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([storyId, viewerId])
}

// ─── Safety ──────────────────────────────────────────────────────────────────

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetId   String
  targetType ReportTarget
  reason     String
  createdAt  DateTime     @default(now())

  reporter User @relation(fields: [reporterId], references: [id], onDelete: Cascade)
}

// ─── Post Extend Vote ────────────────────────────────────────────────────────

model PostExtendVote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ─── Highlights ──────────────────────────────────────────────────────────────

model Highlight {
  id        String          @id @default(cuid())
  userId    String
  title     String
  coverUrl  String?
  createdAt DateTime        @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts HighlightPost[]
}

model HighlightPost {
  id          String    @id @default(cuid())
  highlightId String
  mediaUrl    String
  mediaType   MediaType
  caption     String?
  addedAt     DateTime  @default(now())

  highlight Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
}

// ─── Challenges ──────────────────────────────────────────────────────────────

model Challenge {
  id          String   @id @default(cuid())
  title       String
  description String
  hashtag     String   @unique
  coverUrl    String?
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
}

// ─── Luxe Coins ──────────────────────────────────────────────────────────────

model LuxeCoin {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  postId     String?
  amount     Int
  message    String?
  createdAt  DateTime @default(now())

  sender   User  @relation("CoinSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User  @relation("CoinReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  post     Post? @relation(fields: [postId], references: [id], onDelete: SetNull)
}

// ─── Momento ─────────────────────────────────────────────────────────────────

model Momento {
  id        String        @id @default(cuid())
  userId    String
  latitude  Float
  longitude Float
  label     String?
  expiresAt DateTime
  createdAt DateTime      @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  viewers MomentoView[]
}

model MomentoView {
  id        String   @id @default(cuid())
  momentoId String
  viewerId  String
  createdAt DateTime @default(now())

  momento Momento @relation(fields: [momentoId], references: [id], onDelete: Cascade)
  viewer  User    @relation("MomentoViewer", fields: [viewerId], references: [id], onDelete: Cascade)

  @@unique([momentoId, viewerId])
}

// ─── Device Tokens ───────────────────────────────────────────────────────────

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
}

// ─── Collaborative Post ──────────────────────────────────────────────────────

model CollabPost {
  id         String     @id @default(cuid())
  userAId    String
  userBId    String?
  mediaUrlA  String
  mediaUrlB  String?
  mediaTypeA MediaType
  mediaTypeB MediaType?
  caption    String?
  code       String     @unique
  accepted   Boolean    @default(false)
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())

  userA User  @relation("CollabA", fields: [userAId],  references: [id], onDelete: Cascade)
  userB User? @relation("CollabB", fields: [userBId],  references: [id], onDelete: SetNull)
}

// ─── Follow ───────────────────────────────────────────────────────────────────

model Follow {
  id          String    @id @default(cuid())
  followerId  String
  followingId String
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  follower  User @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

// ─── Donations (Piedade) ─────────────────────────────────────────────────────

enum DonationType {
  ITEM
  FINANCIAL
}

enum DonationStatus {
  AVAILABLE
  RESERVED
  DELIVERED
  EXPIRED
}

model Donation {
  id          String         @id @default(cuid())
  title       String
  description String?
  photos      String[]
  lat         Float
  lng         Float
  radiusKm    Float          @default(10)
  type        DonationType
  status      DonationStatus @default(AVAILABLE)
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  donorId     String
  donor       User           @relation("DonorDonations",     fields: [donorId],     references: [id], onDelete: Cascade)
  requesterId String?
  requester   User?          @relation("RequesterDonations", fields: [requesterId], references: [id], onDelete: SetNull)
  feedbacks   DonationFeedback[]
}

model DonationFeedback {
  id         String   @id @default(cuid())
  donationId String
  fromUserId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  donation   Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  from       User     @relation("FeedbackGiver", fields: [fromUserId], references: [id], onDelete: Cascade)
}

// ─── União (Duo Profile) ─────────────────────────────────────────────────────

enum UnionInviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Union {
  id        String   @id @default(cuid())
  name      String
  avatar    String?
  label     String?
  bio       String?
  memberAId String
  memberBId String
  createdAt DateTime  @default(now())

  memberA  User           @relation("UnionMemberA", fields: [memberAId], references: [id], onDelete: Cascade)
  memberB  User           @relation("UnionMemberB", fields: [memberBId], references: [id], onDelete: Cascade)
  sentMessages     UnionMessage[] @relation("UnionSender")
  receivedMessages UnionMessage[] @relation("UnionReceiver")
  invitesSent      UnionInvite[]  @relation("InviteFromUnion")

  @@unique([memberAId, memberBId])
  @@index([memberAId])
  @@index([memberBId])
}

model UnionInvite {
  id          String            @id @default(cuid())
  fromUnionId String
  toUserId    String
  status      UnionInviteStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  fromUnion Union @relation("InviteFromUnion", fields: [fromUnionId], references: [id], onDelete: Cascade)
  toUser    User  @relation(fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUnionId, toUserId])
  @@index([toUserId])
}

model UnionMessage {
  id          String   @id @default(cuid())
  fromUnionId String
  toUnionId   String
  content     String?
  mediaUrl    String?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  fromUnion Union @relation("UnionSender",   fields: [fromUnionId], references: [id], onDelete: Cascade)
  toUnion   Union @relation("UnionReceiver", fields: [toUnionId],   references: [id], onDelete: Cascade)

  @@index([fromUnionId, toUnionId, createdAt(sort: Desc)])
  @@index([toUnionId, fromUnionId, createdAt(sort: Desc)])
}

// ─── Pairing (persistent relationship tag between two users) ─────────────────

enum PairingType {
  AMIGOS
  AMORES
  IRMAOS
  BESTS
  BONITONAS
  GEMEAS
  OUTRO
}

enum PairingStatus {
  PENDING
  ACTIVE
  ENDED
}

model Pairing {
  id          String        @id @default(cuid())
  userAId     String
  userBId     String
  type        PairingType
  customLabel String?
  status      PairingStatus @default(PENDING)
  requestedBy String
  createdAt   DateTime      @default(now())
  respondedAt DateTime?
  endedAt     DateTime?

  userA User @relation("PairingUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("PairingUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

// ─── Círculo (caça a objetos do mundo real, verificada pela comunidade) ──────

enum CircleCaptureStatus {
  PENDING
  LIVE
  REJECTED
}

model CircleTarget {
  id        String   @id @default(cuid())
  title     String
  emoji     String
  startsAt  DateTime @default(now())
  endsAt    DateTime
  createdAt DateTime @default(now())

  captures CircleCapture[]
}

model CircleCapture {
  id         String              @id @default(cuid())
  targetId   String
  userId     String
  mediaUrl   String
  overlays   Json?               // camadas de emoji: [{ emoji, x, y }] com x/y em fração 0..1
  status     CircleCaptureStatus @default(PENDING)
  approvals  Int                 @default(0)
  rejections Int                 @default(0)
  createdAt  DateTime            @default(now())

  target CircleTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes  CircleVote[]

  @@unique([targetId, userId])
  @@index([targetId, status])
}

model CircleVote {
  id        String   @id @default(cuid())
  captureId String
  voterId   String
  match     Boolean
  createdAt DateTime @default(now())

  capture CircleCapture @relation(fields: [captureId], references: [id], onDelete: Cascade)
  voter   User          @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([captureId, voterId])
}

// ─── Círculo — sessão de foto em grupo, ao vivo com pessoas próximas ─────────

enum CircleSessionStatus {
  OPEN
  PUBLISHED
  CLOSED
}

enum CircleMemberStatus {
  INVITED
  JOINED
}

model CircleSession {
  id        String              @id @default(cuid())
  hostId    String
  status    CircleSessionStatus @default(OPEN)
  lat       Float?
  lng       Float?
  shotAt    DateTime?           // instante do disparo sincronizado (contagem decrescente)
  createdAt DateTime            @default(now())

  host    User                  @relation("CircleHost", fields: [hostId], references: [id], onDelete: Cascade)
  members CircleSessionMember[]

  @@index([hostId, status])
}

model CircleSessionMember {
  id        String             @id @default(cuid())
  sessionId String
  userId    String
  status    CircleMemberStatus @default(JOINED)
  photoUrl  String?
  photoAt   DateTime?          // quando a foto entrou — abre a janela de publicação
  overlays  Json?              // emojis colados na foto: [{ emoji, x, y }] (x/y fração 0..1)
  createdAt DateTime           @default(now())

  session CircleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User          @relation("CircleMember", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId, status])
}

// ─── PasswordReset ────────────────────────────────────────────────────────────

model PasswordReset {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone])
}
